# APG Flight Agent - local config
# Copy this file to .env.local for localhost testing.

NODE_ENV=development

# Supabase Postgres - runtime connection via pooler (port 6543).
# Example:
# DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DATABASE_URL=

# Supabase Postgres - direct connection for Prisma migrate (port 5432).
# Example:
# DIRECT_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"
DIRECT_URL=

# Auth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Seed Super Admin đầu tiên
SEED_SUPER_ADMIN_EMAIL=admin@tanphuapg.com
SEED_SUPER_ADMIN_PASSWORD=ChangeMeImmediately!2026
SEED_SUPER_ADMIN_NAME=Super Admin

# Upstash Redis cho rate limit login (optional).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Nam Thanh Auto Login backend.
# Start it from:
#   F:\Làm việc Ai\namthanh-auto update claude\namthanh-auto-login
#   npm run ocr
#   npm run login
#   npm run api
NAMTHANH_BACKEND_URL=http://localhost:3100
NAMTHANH_BACKEND_API_KEY=
SEARCH_FLIGHT_PRESENTATION_LIMIT=120
SEARCH_PAIR_PRESENTATION_LIMIT=140
SEARCH_PAIR_SOURCE_LIMIT=70

# Next.js app port, default 3000.
# PORT=3000

# API key for n8n routes: /api/n8n/*
API_SECRET_KEY=your-secret-key-here

# Email transactional (optional, disabled by default).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@tanphuapg.com
EMAIL_REPLY_TO=support@tanphuapg.com

# Internal alerts (optional, disabled by default).
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFICATIONS_EMAIL_ENABLED=false
NOTIFICATIONS_SLACK_ENABLED=false
NOTIFICATIONS_TELEGRAM_ENABLED=false
CRON_SECRET=

# payOS QR + webhook (Phase 2, optional until QR module is enabled).
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_LOG_LEVEL=warn
# Optional override. Use {bookingId} placeholder if needed.
PAYOS_RETURN_URL=http://localhost:3000/admin/bookings/{bookingId}?payment=success
PAYOS_CANCEL_URL=http://localhost:3000/admin/bookings/{bookingId}?payment=cancelled
PAYOS_WEBHOOK_URL=http://localhost:3000/api/webhooks/payos

{
  "name": "apg-flight-agent",
  "version": "2.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "test": "tsx --test \"lib/**/*.test.ts\" \"app/**/*.test.ts\" \"components/**/*.test.tsx\"",
    "test:ci": "npm run test",
    "test:e2e": "next build && playwright test",
    "test:watch": "tsx --test --watch \"lib/**/*.test.ts\" \"app/**/*.test.ts\" \"components/**/*.test.tsx\"",
    "lint": "next lint",
    "check:text": "node scripts/check-text-encoding.js",
    "db:migrate:dev": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:seed": "dotenv -e .env.local -- prisma db seed",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:generate": "dotenv -e .env.local -- prisma generate"
  },
  "prisma": {
    "seed": "node --experimental-strip-types prisma/seed.ts"
  },
  "dependencies": {
    "@payos/node": "^2.0.5",
    "@prisma/client": "^6.19.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/functions": "^3.7.5",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^1.9.0",
    "next": "14.2.32",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "prisma": "^6.19.3",
    "qrcode.react": "^4.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-window": "^2.2.7",
    "uuid": "^11.1.0",
    "zod": "^4.1.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.19.13",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
